# FinAudit Investigator Environment Configuration
# Copy this file to .env and configure the keys

# The Gemini API Key obtained from Google AI Studio (Required)
GEMINI_API_KEY=

# The Google GenAI model to use (Default: gemini-3.5-flash)
MODEL_NAME=gemini-3.5-flash

# Port for FastAPI application to run on (Default: 3000)
PORT=3000
